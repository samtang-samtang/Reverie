# 不填也能跑（自动走内置 Mock 流式生成器）。
# 想接真实大模型时，复制本文件为 .env（或 .env.local）。优先读 ARK_*，其次 LLM_*。

# ── 方案 A：火山方舟 Ark / BytePlus（豆包 Seed 系列，OpenAI 兼容）──
# ARK_API_KEY=ark-xxxx
# ARK_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
# ARK_MODEL=seed-2-0-mini-260428      # seed-mini；也可填 endpoint id（ep-xxxx）

# 生图模型与预算（防止 demo 超支）：
# ARK_IMAGE_MODEL=seedream-4-5-251128   # ¥0.25/张 或 $0.04/张
# IMAGE_BUDGET=8                        # 本进程最多生成几张图，超出后复用现有图

# ── 方案 B：任意 OpenAI 兼容服务（OpenAI / DeepSeek / Moonshot / 通义 等）──
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-xxxx
# LLM_MODEL=gpt-4o-mini

# ── 线上持久化（Vercel 部署建议配置）──
# Supabase Postgres：保存故事包 JSON，避免 serverless /tmp 丢数据
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# SUPABASE_STORIES_TABLE=stories

# Vercel Blob：保存生成后的图片/视频，避免 ARK 临时 URL 过期
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
